generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum SyncOperationType {
  CREATE
  UPDATE
  DELETE
}

enum SyncOperationStatus {
  APPLIED
  CONFLICT
  REJECTED
}

model User {
  id                String             @id @default(uuid())
  email             String             @unique
  passwordHash      String
  name              String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  deletedAt         DateTime?
  tasks             Task[]
  sessions          Session[]
  pushSubscriptions PushSubscription[]
  syncOperations    SyncOperation[]

  @@index([createdAt])
  @@index([deletedAt])
}

model Session {
  id               String   @id @default(uuid())
  userId           String
  refreshTokenHash String   @unique
  userAgent        String?
  ipAddress        String?
  expiresAt        DateTime
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  revokedAt        DateTime?
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
}

model Task {
  id              String       @id @default(uuid())
  userId          String
  title           String
  description     String?
  status          TaskStatus   @default(TODO)
  priority        TaskPriority @default(MEDIUM)
  dueDate         DateTime?
  reminderAt      DateTime?
  reminderSentAt  DateTime?
  version         Int          @default(1)
  clientCreatedAt DateTime?
  clientUpdatedAt DateTime?
  lastOperationId String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  deletedAt       DateTime?
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  syncOperations  SyncOperation[]

  @@index([userId, deletedAt, updatedAt])
  @@index([userId, status, deletedAt])
  @@index([userId, priority, deletedAt])
  @@index([userId, dueDate])
  @@index([userId, reminderAt, reminderSentAt])
  @@index([lastOperationId])
}

model SyncOperation {
  id            String              @id @default(uuid())
  userId        String
  taskId        String?
  operationId   String
  operationType SyncOperationType
  taskVersion   Int?
  status        SyncOperationStatus @default(APPLIED)
  payload       Json?
  result        Json?
  errorMessage  String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  task          Task?               @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@unique([userId, operationId])
  @@index([userId, createdAt])
  @@index([taskId])
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  endpoint  String   @unique
  p256dhKey String
  authKey   String
  expiresAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, deletedAt])
}
